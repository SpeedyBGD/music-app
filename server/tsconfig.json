{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "allowJs": true,
    "outDir": "dist",
    "paths": {
      "@server/*": ["./*"]
    }
  },
  "include": ["./**/*.ts", "server.ts"],
  "exclude": ["node_modules", "dist"]
}
